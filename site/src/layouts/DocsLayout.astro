---
import { readdirSync, readFileSync } from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

const frontmatter = Astro.props.frontmatter ?? {};
const baseUrl = import.meta.env.BASE_URL ?? "/";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const sourceDocsDir = path.resolve(__dirname, "..", "..", "..", "docs");

const docsFiles = readdirSync(sourceDocsDir)
  .filter((name) => name.toLowerCase().endsWith(".md"))
  .sort((a, b) => a.localeCompare(b));

const docsPages = docsFiles.map((name) => {
  const sourceText = readFileSync(path.join(sourceDocsDir, name), "utf8");
  const heading = sourceText.match(/^#\s+(.+)\s*$/m)?.[1];
  const slug = name.toLowerCase() === "readme.md" ? "" : name.replace(/\.md$/i, "");
  const title = heading ?? (slug === "" ? "Documentation" : slug.replace(/[-_]/g, " "));
  return {
    title,
    href: slug === "" ? `${baseUrl}docs/` : `${baseUrl}docs/${slug}/`
  };
});

const currentPath = Astro.url.pathname;
const sourceFile = frontmatter.sourceFile ? String(frontmatter.sourceFile) : "";
const editOnGitHubHref = sourceFile
  ? `https://github.com/simplyblock/postbrain/blob/main/docs/${sourceFile}`
  : "https://github.com/simplyblock/postbrain/tree/main/docs";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title ? `${frontmatter.title} | Postbrain Docs` : "Postbrain Docs"}</title>
    <style>
      :root {
        --bg: #0f1117;
        --bg-surface: #1a1d27;
        --bg-hover: #22263a;
        --border: #2d3148;
        --text: #e2e8f0;
        --text-muted: #8892a4;
        --accent: #6c8cff;
        --accent-dim: #3a4a8a;
        --nav-width: 260px;
        --radius: 8px;
        --font: "Inter", system-ui, -apple-system, sans-serif;
        --font-mono: "JetBrains Mono", "Fira Code", ui-monospace, monospace;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        min-height: 100vh;
        color: var(--text);
        background: var(--bg);
        font-family: var(--font);
        line-height: 1.6;
        display: grid;
        grid-template-columns: var(--nav-width) 1fr;
      }
      nav {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        background: var(--bg-surface);
        border-right: 1px solid var(--border);
        padding: 1rem 0;
      }
      nav .brand {
        display: block;
        padding: 0.5rem 1.2rem 1rem;
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
        letter-spacing: 0.02em;
      }
      nav .caption {
        padding: 0.4rem 1.2rem 0.5rem;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
      }
      nav a.page-link {
        display: block;
        padding: 0.42rem 1.2rem;
        text-decoration: none;
        color: var(--text-muted);
        border-left: 3px solid transparent;
        transition: color 0.14s, background 0.14s, border-color 0.14s;
      }
      nav a.page-link:hover {
        background: var(--bg-hover);
        color: var(--text);
        border-left-color: var(--accent-dim);
      }
      nav a.page-link.active {
        color: var(--text);
        background: color-mix(in srgb, var(--accent) 14%, transparent);
        border-left-color: var(--accent);
      }
      .content-wrap {
        min-width: 0;
      }
      header {
        padding: 1rem 1.8rem;
        border-bottom: 1px solid var(--border);
        background: color-mix(in srgb, var(--bg-surface) 65%, var(--bg));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .header-title {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-muted);
      }
      .header-actions a {
        color: var(--accent);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .header-actions a:hover {
        text-decoration: underline;
      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem 1.8rem 3rem;
      }
      :global(article h1) { font-size: 1.8rem; margin: 0.4rem 0 1rem; }
      :global(article h2) { margin-top: 1.8rem; font-size: 1.24rem; }
      :global(article h3) { margin-top: 1.3rem; font-size: 1.04rem; }
      :global(article p), :global(article li) { color: var(--text); }
      :global(article ul), :global(article ol) { padding-left: 1.2rem; }
      :global(article a) { color: var(--accent); text-decoration: none; }
      :global(article a:hover) { text-decoration: underline; }
      :global(article code) {
        font-family: var(--font-mono);
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.1rem 0.35rem;
        font-size: 0.9em;
      }
      :global(article pre) {
        font-family: var(--font-mono);
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.95rem 1rem;
        overflow-x: auto;
      }
      :global(article blockquote) {
        margin: 1rem 0;
        border-left: 3px solid var(--accent-dim);
        padding: 0.25rem 0 0.25rem 0.8rem;
        color: var(--text-muted);
      }
      @media (max-width: 1024px) {
        body {
          grid-template-columns: 1fr;
        }
        nav {
          position: static;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--border);
          max-height: 260px;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <a class="brand" href={`${baseUrl}docs/`}>Postbrain Docs</a>
      <div class="caption">Contents</div>
      {
        docsPages.map((page) => (
          <a
            class={`page-link ${currentPath === page.href ? "active" : ""}`}
            href={page.href}
          >
            {page.title}
          </a>
        ))
      }
    </nav>

    <div class="content-wrap">
      <header>
        <p class="header-title">{frontmatter.title ?? "Postbrain Documentation"}</p>
        <div class="header-actions">
          <a href={editOnGitHubHref} target="_blank" rel="noreferrer">Edit on GitHub</a>
        </div>
      </header>
      <main>
        <article>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>
