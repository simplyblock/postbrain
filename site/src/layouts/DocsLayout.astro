---
import navData from "../generated/docs-nav.json";

const frontmatter = Astro.props.frontmatter ?? {};
const baseUrl = import.meta.env.BASE_URL ?? "/";

const navSections = navData.sections.map((section) => ({
  title: section.title,
  pages: section.pages.map((p) => ({
    title: p.title,
    href: `${baseUrl}docs/${p.slug}/`
  }))
}));

const currentPath = Astro.url.pathname;
const sourceFile = frontmatter.sourceFile ? String(frontmatter.sourceFile) : "";
const editOnGitHubHref = sourceFile
  ? `https://github.com/simplyblock/postbrain/blob/main/docs/${sourceFile}`
  : "https://github.com/simplyblock/postbrain/tree/main/docs";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title ? `${frontmatter.title} | Postbrain Docs` : "Postbrain Docs"}</title>
    <style>
      :root {
        --bg: #0f1117;
        --bg-surface: #1a1d27;
        --bg-hover: #22263a;
        --border: #2d3148;
        --text: #e2e8f0;
        --text-muted: #8892a4;
        --accent: #6c8cff;
        --accent-dim: #3a4a8a;
        --nav-width: 260px;
        --radius: 8px;
        --font: "Inter", system-ui, -apple-system, sans-serif;
        --font-mono: "JetBrains Mono", "Fira Code", ui-monospace, monospace;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        min-height: 100vh;
        color: var(--text);
        background: var(--bg);
        font-family: var(--font);
        line-height: 1.6;
        display: grid;
        grid-template-columns: var(--nav-width) 1fr;
      }
      nav {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        background: var(--bg-surface);
        border-right: 1px solid var(--border);
        padding: 1rem 0;
      }
      nav .brand {
        display: block;
        padding: 0.5rem 1.2rem 1rem;
        color: var(--accent);
        text-decoration: none;
        font-weight: 700;
        letter-spacing: 0.02em;
      }
      nav .caption {
        padding: 0.4rem 1.2rem 0.5rem;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
      }
      nav .caption:not(:first-of-type) {
        margin-top: 0.9rem;
      }
      nav a.page-link {
        display: block;
        padding: 0.42rem 1.2rem;
        text-decoration: none;
        color: var(--text-muted);
        border-left: 3px solid transparent;
        transition: color 0.14s, background 0.14s, border-color 0.14s;
      }
      nav a.page-link:hover {
        background: var(--bg-hover);
        color: var(--text);
        border-left-color: var(--accent-dim);
      }
      nav a.page-link.active {
        color: var(--text);
        background: color-mix(in srgb, var(--accent) 14%, transparent);
        border-left-color: var(--accent);
      }
      nav .section-end {
        margin-bottom: 0.9rem;
      }
      .content-wrap {
        min-width: 0;
      }
      header {
        padding: 1rem 1.8rem;
        border-bottom: 1px solid var(--border);
        background: color-mix(in srgb, var(--bg-surface) 65%, var(--bg));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .header-title {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-muted);
      }
      .header-actions a {
        color: var(--accent);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .header-actions a:hover {
        text-decoration: underline;
      }
      main {
        max-width: 960px;
        margin: 0;
        padding: 1.5rem 2rem 3rem;
      }
      :global(article h1) { font-size: 1.8rem; margin: 0.4rem 0 1rem; }
      :global(article h2) { margin-top: 1.8rem; font-size: 1.24rem; }
      :global(article h3) { margin-top: 1.3rem; font-size: 1.04rem; }
      :global(article p), :global(article li) { color: var(--text); }
      :global(article ul), :global(article ol) { padding-left: 1.2rem; }
      :global(article a) { color: var(--accent); text-decoration: none; }
      :global(article a:hover) { text-decoration: underline; }
      :global(article :not(pre) > code) {
        font-family: var(--font-mono);
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.1rem 0.35rem;
        font-size: 0.9em;
      }
      :global(article pre) {
        font-family: var(--font-mono);
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.7rem 0.85rem;
        overflow-x: auto;
        margin: 0.8rem 0 1rem;
      }
      :global(article pre.astro-code) {
        background: linear-gradient(180deg, #1f2433 0%, #1a1d27 100%) !important;
        border-color: #303854;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
        font-size: 0.88rem;
        line-height: 1.16 !important;
        padding-top: 0.72rem;
        padding-bottom: 0.72rem;
      }
      :global(article pre.astro-code code) {
        background: transparent;
        border: 0;
        padding: 0;
        color: #dbe5ff;
        font-size: inherit;
        line-height: inherit !important;
        white-space: normal !important;
        font-variant-ligatures: none;
        display: block;
      }
      :global(article pre.astro-code .line) {
        display: block;
        min-height: 0 !important;
        line-height: inherit !important;
        margin: 0 !important;
        padding: 0 !important;
        white-space: pre !important;
      }
      :global(article pre.astro-code .line:empty) { display: none; }
      :global(article pre.astro-code .line + .line) { margin-top: 0 !important; }
      :global(article pre.astro-code span) {
        text-decoration: none !important;
        line-height: inherit !important;
        vertical-align: baseline !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      :global(article blockquote) {
        margin: 1rem 0;
        border-left: 3px solid var(--accent-dim);
        padding: 0.25rem 0 0.25rem 0.8rem;
        color: var(--text-muted);
      }
      :global(article img) {
        display: block;
        max-width: 100%;
        width: auto;
        height: auto;
        margin: 0.9rem 0 1.2rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: color-mix(in srgb, var(--bg-surface) 90%, #0f1320);
      }
      :global(article table) {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 1rem 0 1.4rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: color-mix(in srgb, var(--bg-surface) 88%, #111522);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      }
      :global(article thead th) {
        text-align: left;
        font-weight: 650;
        color: #e8eeff;
        background: linear-gradient(180deg, #242b40 0%, #20263a 100%);
        border-bottom: 1px solid #343d59;
        padding: 0.62rem 0.78rem;
      }
      :global(article tbody td) {
        padding: 0.52rem 0.78rem;
        color: var(--text);
        border-bottom: 1px solid rgba(56, 66, 96, 0.75);
        vertical-align: top;
      }
      :global(article tbody tr:nth-child(even) td) {
        background: rgba(137, 164, 255, 0.035);
      }
      :global(article tbody tr:hover td) {
        background: rgba(108, 140, 255, 0.08);
      }
      :global(article tbody tr:last-child td) {
        border-bottom: 0;
      }
      :global(article table code) {
        font-size: 0.84em;
      }
      @media (max-width: 1024px) {
        body {
          grid-template-columns: 1fr;
        }
        nav {
          position: static;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--border);
          max-height: 260px;
        }
      }
      @media (max-width: 760px) {
        :global(article table) {
          display: block;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
      }
    </style>
  </head>
  <body>
    <nav>
      <a class="brand" href={`${baseUrl}docs/`}>Postbrain Docs</a>
      {
        navSections.map((section) => (
          <>
            <div class="caption">{section.title}</div>
            {
              section.pages.map((page) => (
                <a
                  class={`page-link ${currentPath === page.href ? "active" : ""} ${page === section.pages[section.pages.length - 1] ? "section-end" : ""}`}
                  href={page.href}
                >
                  {page.title}
                </a>
              ))
            }
          </>
        ))
      }
    </nav>

    <div class="content-wrap">
      <header>
        <p class="header-title">{frontmatter.title ?? "Postbrain Documentation"}</p>
        <div class="header-actions">
          <a href={editOnGitHubHref} target="_blank" rel="noreferrer">Edit on GitHub</a>
        </div>
      </header>
      <main>
        <article>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>
