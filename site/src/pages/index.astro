---
import navData from "../generated/docs-nav.json";

const baseUrl = import.meta.env.BASE_URL ?? "/";

const highlightSlugs = new Set([
  "getting-started",
  "server-installation",
  "configuration",
  "using-with-coding-agents",
  "common-workflows",
  "security",
  "indexing-model"
]);

const allPages = navData.sections.flatMap((s) =>
  s.pages.map((p) => ({
    slug: p.slug,
    title: p.title,
    href: `${baseUrl}docs/${p.slug}/`
  }))
);

const highlightDocs = allPages.filter((p) => highlightSlugs.has(p.slug));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Postbrain: Infinite Enterprise-Memory for your AI Agents and Teams</title>
    <style>
      :root {
        --bg: #0f1117;
        --bg-surface: #1a1d27;
        --bg-hover: #22263a;
        --border: #2d3148;
        --text: #e2e8f0;
        --text-muted: #8892a4;
        --accent: #6c8cff;
        --accent-soft: rgba(108, 140, 255, 0.16);
        --success: #63d9a1;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background:
          radial-gradient(circle at 5% 0%, #1f2846 0%, transparent 34%),
          radial-gradient(circle at 90% 10%, #1a2442 0%, transparent 30%),
          var(--bg);
        color: var(--text);
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        line-height: 1.5;
      }
      .topbar {
        position: sticky;
        top: 0;
        z-index: 5;
        border-bottom: 1px solid rgba(45, 49, 72, 0.8);
        backdrop-filter: blur(8px);
        background: rgba(15, 17, 23, 0.8);
      }
      .topbar-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0.8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .brand {
        color: var(--text);
        font-weight: 700;
        letter-spacing: 0.01em;
        text-decoration: none;
      }
      .top-links {
        display: flex;
        gap: 0.9rem;
      }
      .top-links a {
        color: var(--text-muted);
        text-decoration: none;
      }
      .top-links a:hover {
        color: var(--text);
      }
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }
      .hero {
        display: block;
      }
      .hero-main {
        background: linear-gradient(180deg, #1a1f31 0%, #151a29 100%);
        border: 1px solid #313a58;
        border-radius: 14px;
        padding: 1.4rem 1.45rem;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.25rem 0.55rem;
        font-size: 0.78rem;
        color: #b8c9ff;
        background: var(--accent-soft);
        border: 1px solid rgba(108, 140, 255, 0.35);
        border-radius: 999px;
      }
      .hero h1 {
        margin: 0.8rem 0 0.75rem;
        font-size: clamp(1.85rem, 3.2vw, 2.65rem);
        line-height: 1.15;
      }
      .lead {
        margin: 0 0 1rem;
        color: var(--text-muted);
        max-width: 72ch;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .cta-row {
        margin-top: 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        padding: 0.58rem 0.95rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
      }
      .btn.primary {
        background: color-mix(in srgb, var(--accent) 22%, #0f1322);
        border-color: #4a61b5;
        color: #e7edff;
      }
      .btn.muted {
        background: rgba(26, 29, 39, 0.9);
        color: var(--text-muted);
      }
      .quick {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem 1.05rem;
      }
      .quick h2 {
        margin: 0 0 0.6rem;
        font-size: 1rem;
      }
      .quick ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.38rem 0.9rem;
      }
      .quick li {
        margin: 0;
      }
      .quick code {
        color: #dbe5ff;
      }
      .section {
        margin-top: 1.2rem;
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem;
      }
      .section h2 {
        margin: 0 0 0.7rem;
        font-size: 1.08rem;
      }
      .kicker {
        margin: 0 0 0.85rem;
        color: var(--text-muted);
        font-size: 0.95rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.9rem;
      }
      .card {
        background: rgba(18, 22, 34, 0.95);
        border: 1px solid #2a314b;
        border-radius: 8px;
        padding: 0.85rem 0.9rem;
      }
      .card h2 {
        margin: 0 0 0.4rem;
        font-size: 0.97rem;
      }
      .card p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      .steps {
        list-style: none;
        margin: 0 0 0.9rem;
        padding: 0;
        position: relative;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.9rem;
      }
      .steps::before {
        content: "";
        position: absolute;
        left: 12%;
        right: 12%;
        top: 16px;
        height: 2px;
        background: linear-gradient(90deg, rgba(108, 140, 255, 0.55) 0%, rgba(108, 140, 255, 0.18) 100%);
      }
      .steps li {
        position: relative;
        padding-top: 2.65rem;
        text-align: center;
      }
      .steps li::before {
        content: attr(data-step);
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        border: 1px solid rgba(108, 140, 255, 0.6);
        background: radial-gradient(circle at 35% 20%, #4f67b9 0%, #2a345c 75%);
        color: #ebf1ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.84rem;
        font-weight: 700;
        z-index: 1;
      }
      .steps strong {
        color: #e8eeff;
      }
      .steps .step-label {
        font-weight: 700;
        color: #e8eeff;
        font-size: 0.98rem;
      }
      .step-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.9rem;
      }
      .step-card {
        background: rgba(19, 24, 39, 0.92);
        border: 1px solid #2d3754;
        border-radius: 10px;
        padding: 0.65rem 0.72rem;
      }
      .step-card p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.92rem;
      }
      .split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.9rem;
      }
      .list-clean {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .list-clean li {
        margin: 0;
        padding: 0.35rem 0;
        color: var(--text);
        border-bottom: 1px dashed rgba(57, 70, 105, 0.65);
      }
      .list-clean li:last-child {
        border-bottom: 0;
      }
      .meta {
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      pre {
        margin: 0.8rem 0 0;
        overflow-x: auto;
        border-radius: 10px;
        border: 1px solid #303854;
        background: linear-gradient(180deg, #1f2433 0%, #1a1d27 100%);
        padding: 0.7rem 0.8rem;
      }
      pre code {
        font-family: "JetBrains Mono", "Fira Code", ui-monospace, monospace;
        font-size: 0.86rem;
        line-height: 1.22;
        color: #dbe5ff;
      }
      .footer-note {
        margin-top: 1.2rem;
        color: var(--text-muted);
        font-size: 0.9rem;
      }
      .tick {
        color: var(--success);
        font-weight: 700;
        margin-right: 0.3rem;
      }
      @media (max-width: 600px) {
        .top-links {
          gap: 0.55rem;
          font-size: 0.92rem;
        }
        .container {
          padding: 1.15rem 0.75rem 2.2rem;
        }
        .quick ul {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 860px) {
        .split {
          grid-template-columns: 1fr;
        }
        .steps {
          grid-template-columns: 1fr 1fr;
        }
        .steps::before {
          left: 10%;
          right: 10%;
        }
        .step-grid {
          grid-template-columns: 1fr 1fr;
        }
      }
      @media (max-width: 600px) {
        .steps {
          grid-template-columns: 1fr;
        }
        .steps::before {
          display: none;
        }
        .step-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href={baseUrl}>Postbrain</a>
        <nav class="top-links">
          <a href={`${baseUrl}docs/getting-started/`}>Getting Started</a>
          <a href={`${baseUrl}docs/`}>Documentation</a>
          <a href="https://github.com/simplyblock/postbrain" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <div class="container">
      <section class="hero">
        <article class="hero-main">
          <span class="badge">Making Agents Enterprise-Ready</span>
          <h1>Make AI agents reliable, governable, and team-ready.</h1>
          <p class="lead">
            Postbrain adds durable memory, reviewed knowledge, and reusable skills to agent workflows. It turns
            session-only output into governed, reusable organizational context.
          </p>
          <p class="lead">
            Default assistant memory is often isolated per user/account/device/agent context. Postbrain makes context
            portable with explicit scope boundaries, auditability, and operational control at project, team, and
            company levels.
          </p>
          <div class="cta-row">
            <a class="btn primary" href={`${baseUrl}docs/getting-started/`}>Get Started</a>
            <a class="btn muted" href={`${baseUrl}docs/common-workflows/`}>See Workflows</a>
            <a class="btn muted" href={`${baseUrl}docs/server-installation/`}>Install Server</a>
          </div>
        </article>
      </section>

      <section class="section quick">
        <h2>Quickstart</h2>
        <ul>
          <li><span class="tick">✓</span> Install server/client with one hosted script</li>
          <li><span class="tick">✓</span> Deploy server and run `postbrain onboard`</li>
          <li><span class="tick">✓</span> Issue a scoped token for your automation/user</li>
          <li><span class="tick">✓</span> Install Codex/Claude skill in your repo</li>
          <li><span class="tick">✓</span> Start storing and recalling context per scope</li>
          <li><span class="tick">✓</span> Collaborate with team members in shared scopes</li>
        </ul>
        <pre><code>curl -fsSL https://simplyblock.github.io/postbrain/install-postbrain.sh | bash -s -- server
curl -fsSL https://simplyblock.github.io/postbrain/install-postbrain.sh | bash -s -- client
postbrain onboard --config ./config.yaml
postbrain token create --name "project-bot" --principal "team-platform"
postbrain-cli install-codex-skill --target /path/to/repo</code></pre>
      </section>

      <section class="section">
        <h2>What You Get</h2>
        <p class="kicker">A memory system designed for engineering workflows, not just chat history.</p>
        <div class="grid">
          <article class="card">
            <h2>Reliable Memory Layer</h2>
            <p>Capture decisions, observations, and task progress continuously and recall them in later sessions.</p>
          </article>
          <article class="card">
            <h2>Knowledge Promotion</h2>
            <p>Promote stable outcomes into reviewed artifacts so high-value context becomes durable reference.</p>
          </article>
          <article class="card">
            <h2>Skill Sharing Across Teams</h2>
            <p>Publish and reuse skills across scopes so proven agent behaviors become shared team/company assets.</p>
          </article>
          <article class="card">
            <h2>Hybrid Retrieval</h2>
            <p>Combine vector, full-text, trigram, and graph-aware retrieval for higher recall quality.</p>
          </article>
          <article class="card">
            <h2>Enterprise Access Controls</h2>
            <p>Apply project/team/company boundaries so context sharing is explicit, auditable, and safe.</p>
          </article>
          <article class="card">
            <h2>Agent Governance Tooling</h2>
            <p>Use `postbrain-cli` and skills for Codex/Claude to integrate memory into everyday coding loops.</p>
          </article>
          <article class="card">
            <h2>MCP + REST Interfaces</h2>
            <p>Integrate through MCP tools for agents and REST endpoints for backend services and automation.</p>
          </article>
          <article class="card">
            <h2>Production-Grade Deployment</h2>
            <p>Run locally, in containers, or on Kubernetes with Helm and OAuth/social login support.</p>
          </article>
        </div>
      </section>

      <section class="section">
        <h2>Ecosystem Support</h2>
        <p class="kicker">Use Postbrain with common coding agents and flexible model backends.</p>
        <div class="split">
          <article class="card">
            <h2>Supported Agent Integrations</h2>
            <ul class="list-clean">
              <li><strong>OpenAI Codex</strong> via installable Codex skill</li>
              <li><strong>Claude Code</strong> via installable Claude skill</li>
              <li><strong>ChatGPT-based flows</strong> via API/backend integration</li>
              <li><strong>Mixed-agent repositories</strong> sharing one scoped memory model</li>
            </ul>
            <p class="meta">
              See <a href={`${baseUrl}docs/using-with-coding-agents/`}>Using with Coding Agents</a> and
              <a href={`${baseUrl}docs/using-with-chatgpt/`}> Using with ChatGPT</a>.
            </p>
          </article>
          <article class="card">
            <h2>Model and Backend Support</h2>
            <ul class="list-clean">
              <li><strong>OpenAI-compatible backends</strong> for embedding/analyze paths</li>
              <li><strong>Ollama</strong> for local/self-hosted embedding paths</li>
              <li><strong>Separate text/code embedding models</strong> configurable by slug</li>
              <li><strong>Optional summary/analyze model override</strong> for lifecycle jobs</li>
            </ul>
            <p class="meta">
              See <a href={`${baseUrl}docs/configuration/`}>Configuration</a> (`embedding.*`) and
              <a href={`${baseUrl}docs/indexing-model/`}> Indexing Model</a>.
            </p>
          </article>
        </div>
      </section>

      <section class="section">
        <h2>Typical Flow</h2>
        <ol class="steps">
          <li data-step="1">
            <div class="step-label">Capture</div>
          </li>
          <li data-step="2">
            <div class="step-label">Recall</div>
          </li>
          <li data-step="3">
            <div class="step-label">Promote</div>
          </li>
          <li data-step="4">
            <div class="step-label">Share with control</div>
          </li>
        </ol>
        <div class="step-grid">
          <article class="step-card">
            <p>Agents write memories while implementing, debugging, and reviewing code.</p>
          </article>
          <article class="step-card">
            <p>New tasks start by pulling relevant context in the same project/team scope.</p>
          </article>
          <article class="step-card">
            <p>Stable outcomes become knowledge artifacts and reusable skills.</p>
          </article>
          <article class="step-card">
            <p>Teams consume shared context through explicit, auditable scope boundaries.</p>
          </article>
        </div>
      </section>

      <section class="section">
        <h2>Documentation Entry Points</h2>
        <p class="kicker">Start with these guides for setup, operations, and day-to-day usage.</p>
        <div class="grid">
          {
            highlightDocs.map((page) => (
              <a class="card" href={page.href}>
                <h2>{page.title}</h2>
                <p>Open guide</p>
              </a>
            ))
          }
        </div>
        <p class="footer-note">
          Full reference: <a href={`${baseUrl}docs/`}>Documentation Index</a>
        </p>
      </section>
      <section class="footer-note">
        Postbrain is open source and built to make agent workflows enterprise-ready through durable memory,
        scope-based governance, and production deployment paths.
      </section>
      <div class="footer-note">
        <a href="https://github.com/simplyblock/postbrain" target="_blank" rel="noreferrer">View repository on GitHub</a>
      </div>
    </div>
  </body>
</html>
