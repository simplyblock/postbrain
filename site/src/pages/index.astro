---
import { readdirSync } from "node:fs";

const docsDir = new URL("../../../docs/", import.meta.url);
const pages = readdirSync(docsDir)
  .filter((name) => name.toLowerCase().endsWith(".md"))
  .sort((a, b) => a.localeCompare(b))
  .map((name) => {
    const slug = name.replace(/\.md$/i, "");
    return {
      name,
      slug,
      title: slug.replace(/[-_]/g, " ")
    };
  });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Postbrain Docs</title>
    <style>
      :root {
        color-scheme: light;
      }
      body {
        margin: 0 auto;
        max-width: 920px;
        padding: 2rem 1rem 3rem;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        line-height: 1.5;
      }
      h1 {
        margin-top: 0;
      }
      ul {
        padding-left: 1.2rem;
      }
      li + li {
        margin-top: 0.35rem;
      }
      a {
        color: #0b5fff;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .hint {
        color: #444;
        margin-bottom: 1rem;
      }
    </style>
  </head>
  <body>
    <h1>Postbrain Documentation</h1>
    <p class="hint">Generated from the repository <code>docs/</code> directory.</p>
    <ul>
      {
        pages.map((page) => (
          <li>
            <a href={`/docs/${page.slug}/`}>{page.title}</a>
          </li>
        ))
      }
    </ul>
  </body>
</html>
